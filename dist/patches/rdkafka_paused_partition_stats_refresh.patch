+/**
+ * @brief Response handler for the watermark-only ListOffsets probe fired
+ *        by rd_kafka_toppar_wmark_refresh_if_paused() below.
+ *
+ * Unlike rd_kafka_toppar_handle_Offset() this never touches fetch_pos,
+ * fetch_state or query_pos: it only refreshes the watermark used for
+ * statistics (rktp_hi_offset / rktp_ls_offset) so that consumer_lag keeps
+ * advancing while the partition is paused. If the response arrives after
+ * the app already resumed, re-paused, or the partition was
+ * reassigned/removed in the meantime, this is a no-op.
+ *
+ * Mirrors rd_kafka_toppar_lag_handle_Offset() above: no special-casing of
+ * RD_KAFKA_RESP_ERR__DESTROY (it is a routine outcome whenever rktp_ops is
+ * purged, e.g. on unassign/rebalance, not just at client termination), and
+ * the in-flight flag is always cleared unconditionally so it can never get
+ * wedged permanently by a request that dies without a real reply.
+ *
+ * @locality rdkafka main thread, or whichever thread purges rktp_ops.
+ */
+static void rd_kafka_toppar_handle_Offset_wmark(rd_kafka_t *rk,
+                                                rd_kafka_broker_t *rkb,
+                                                rd_kafka_resp_err_t err,
+                                                rd_kafka_buf_t *rkbuf,
+                                                rd_kafka_buf_t *request,
+                                                void *opaque) {
+        rd_kafka_toppar_t *rktp = opaque;
+        rd_kafka_topic_partition_list_t *offsets =
+            rd_kafka_topic_partition_list_new(1);
+        rd_kafka_topic_partition_t *rktpar;
+
+        err = rd_kafka_handle_ListOffsets(rk, rkb, err, rkbuf, request,
+                                          offsets, NULL);
+
+        rd_kafka_toppar_lock(rktp);
+
+        if (!err && !rd_kafka_buf_version_outdated(request,
+                                                    rktp->rktp_op_version) &&
+            (rktpar = rd_kafka_topic_partition_list_find(
+                 offsets, rktp->rktp_rkt->rkt_topic->str,
+                 rktp->rktp_partition)) != NULL &&
+            RD_KAFKA_TOPPAR_IS_PAUSED(rktp)) {
+                /* The request was made with the configured isolation level
+                 * (see rd_kafka_ListOffsetsRequest()), so under
+                 * READ_COMMITTED the returned offset is the
+                 * LastStableOffset, not the true high watermark: only
+                 * ls_offset is authoritative there (rd_kafka_stats_emit_
+                 * toppar() picks ls_offset over hi_offset for lag exactly
+                 * in that case). Writing it into hi_offset too would
+                 * understate the real watermark whenever a transaction is
+                 * open. Under READ_UNCOMMITTED the two coincide, same as
+                 * in the Fetch response handler. */
+                if (rk->rk_conf.isolation_level == RD_KAFKA_READ_COMMITTED)
+                        rktp->rktp_ls_offset = rktpar->offset;
+                else
+                        rktp->rktp_hi_offset = rktp->rktp_ls_offset =
+                            rktpar->offset;
+        }
+
+        rktp->rktp_wmark_query_active = rd_false;
+        rd_kafka_toppar_unlock(rktp);
+
+        rd_kafka_topic_partition_list_destroy(offsets);
+
+        rd_kafka_toppar_destroy(rktp); /* from request opaque */
+}
