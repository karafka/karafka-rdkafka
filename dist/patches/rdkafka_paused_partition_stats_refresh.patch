+/**
+ * @brief If \p rktp is app-paused, issue a lightweight ListOffsets probe to
+ *        keep rktp_hi_offset/rktp_ls_offset (and thus statistics lag)
+ *        from going stale for the duration of the pause: paused partitions
+ *        receive no Fetch responses, which is the only other place these
+ *        fields are updated. No-op if not app-paused, if a probe is
+ *        already in flight, or if
+ *        statistics.paused.refresh.ms has not yet
+ *        elapsed since the last one.
+ *
+ * Deliberately checks RD_KAFKA_TOPPAR_F_APP_PAUSE rather than
+ * RD_KAFKA_TOPPAR_IS_PAUSED(): the latter is also true for transient
+ * library-internal pauses (offset validation, seeks, rebalance
+ * transitions), which aren't the "paused for a while, want lag to keep
+ * advancing" case this exists for and would otherwise waste a broker
+ * round-trip on every one of them.
+ *
+ * The request always targets rktp_leader, independently of rktp_broker:
+ * unlike the lo_offset request just below (whose FETCH >= v5 short-circuit
+ * assumes reads happen against rktp_broker, which may be a preferred
+ * replica under follower fetching / client.rack), ListOffsets is a
+ * leader-only API regardless of where Fetches are being read from - so
+ * this must not be skipped just because rktp_broker isn't the leader.
+ *
+ * The enclosing timer (rd_kafka_toppar_consumer_lag_req(), see below) ticks
+ * no more often than every 10s regardless of configuration, so this rate
+ * limit is a floor on spacing between queries, not a guarantee of hitting
+ * the configured interval exactly - see the property documentation.
+ *
+ * @locality rdkafka main thread
+ * @locks_required rd_kafka_toppar_lock()
+ */
+static void rd_kafka_toppar_wmark_refresh_if_paused(rd_kafka_toppar_t *rktp) {
+        rd_kafka_topic_partition_list_t *offsets;
+        int interval_ms = rktp->rktp_rkt->rkt_rk->rk_conf
+                              .stats_paused_refresh_ms;
+
+        if (!(rktp->rktp_flags & RD_KAFKA_TOPPAR_F_APP_PAUSE) ||
+            rktp->rktp_wmark_query_active || !rktp->rktp_leader)
+                return;
+
+        if (rktp->rktp_ts_last_wmark_refresh &&
+            rd_clock() - rktp->rktp_ts_last_wmark_refresh <
+                interval_ms * 1000ll)
+                return;
+
+        rktp->rktp_ts_last_wmark_refresh = rd_clock();
+        rktp->rktp_wmark_query_active    = rd_true;
+
+        offsets = rd_kafka_topic_partition_list_new(1);
+        rd_kafka_topic_partition_list_add(offsets,
+                                          rktp->rktp_rkt->rkt_topic->str,
+                                          rktp->rktp_partition)
+            ->offset = RD_KAFKA_OFFSET_END;
+
+        /* Route the reply through rktp_ops (not rk_ops) tagged with the
+         * current op version, same as rd_kafka_toppar_offset_request():
+         * this ties the request's lifetime to the toppar's own queue, so
+         * a pause/resume, unassign, or rebalance that stops this toppar
+         * purges/invalidates it immediately instead of leaving it to
+         * dangle until the ListOffsets round-trip completes on its own. */
+        rd_kafka_ListOffsetsRequest(
+            rktp->rktp_leader, offsets,
+            RD_KAFKA_REPLYQ(rktp->rktp_ops, rktp->rktp_op_version),
+            rd_kafka_toppar_handle_Offset_wmark, -1,
+            rd_kafka_toppar_keep(rktp));
+
+        rd_kafka_topic_partition_list_destroy(offsets);
+}
